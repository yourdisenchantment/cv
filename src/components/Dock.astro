---
import { type Locale } from "../lib/format";
import { t } from "../lib/i18n";
import "../styles/dock.css";

// Resume control dock. Buttons: theme (toggle), code (link to the GitHub
// repo), print/PDF (window.print, styled via print.css), language (link to
// the other locale route). Model B: en at '/', ru at '/ru/'.
interface Props {
    lang: Locale;
}

const { lang } = Astro.props;

const repoUrl = "https://github.com/yourdisenchantment/cv";

// Language button - link to the other locale. Tooltip is the target language
// autonym (recognizable to the user): on en -> "Русский", on ru -> "English".
// Routes under base: BASE_URL ("/cv/") - en root, + "ru/" - the Russian version.
const base = import.meta.env.BASE_URL;
const langHref = lang === "en" ? `${base}ru/` : base;
const langLabel = lang === "en" ? "Русский" : "English";
---

<nav class="dock" aria-label={t(lang, "dockNav")}>
    <a
        class="dock-button"
        href={langHref}
        data-tooltip={langLabel}
        aria-label={langLabel}
    >
        <span class="material-symbols-outlined" aria-hidden="true"
            >language</span
        >
    </a>
    <button
        class="dock-button"
        type="button"
        data-action="theme"
        data-tooltip={t(lang, "themeToggle")}
        aria-label={t(lang, "themeToggle")}
    >
        <span class="material-symbols-outlined" aria-hidden="true">routine</span
        >
    </button>
    <button
        class="dock-button"
        type="button"
        data-action="download"
        data-tooltip={t(lang, "downloadPdf")}
        aria-label={t(lang, "downloadPdf")}
    >
        <span class="material-symbols-outlined" aria-hidden="true"
            >download</span
        >
    </button>
    <button
        class="dock-button"
        type="button"
        data-action="print"
        data-tooltip={t(lang, "print")}
        aria-label={t(lang, "print")}
    >
        <span class="material-symbols-outlined" aria-hidden="true">print</span>
    </button>
    <a
        class="dock-button"
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-tooltip={t(lang, "sourceCode")}
        aria-label={t(lang, "sourceCode")}
    >
        <span class="material-symbols-outlined" aria-hidden="true">code</span>
    </a>
</nav>

<!-- Theme toggle: flips data-theme on <html>, writes to localStorage. The
     inline script in BaseLayout already applied the theme before paint; here
     it is only toggled on click. -->
<script is:inline>
    (function () {
        var btn = document.querySelector('.dock-button[data-action="theme"]');
        if (!btn) return;
        btn.addEventListener("click", function () {
            var cur =
                document.documentElement.getAttribute("data-theme") || "light";
            var next = cur === "dark" ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", next);
            localStorage.setItem("theme", next);
        });
    })();
</script>

<!-- Print and PDF download: both call window.print() (browser dialog, "Save
     as PDF"). Print styling lives in print.css (@page A4). -->
<script is:inline>
    (function () {
        var buttons = document.querySelectorAll(
            '.dock-button[data-action="print"], .dock-button[data-action="download"]',
        );
        buttons.forEach(function (b) {
            b.addEventListener("click", function () {
                window.print();
            });
        });
    })();
</script>
