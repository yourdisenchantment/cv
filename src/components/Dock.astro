---
import { type Locale } from "../lib/format";
import { t } from "../lib/i18n";
import "../styles/dock.css";

// Док-бар управления резюме. Рабочие: тема (toggle), code (ссылка на GitHub-
// репо), печать/PDF (window.print - временно, стилизация печати - этап E),
// язык (ссылка на другой локаль-маршрут). Модель B: en на '/', ru на '/ru/'.
interface Props {
    lang: Locale;
}

const { lang } = Astro.props;

const repoUrl = "https://github.com/yourdisenchantment/cv";

// Кнопка языка - ссылка на другой локаль. Тултип - автоним целевого языка
// (узнаваем пользователем): на en-странице -> "Русский", на ru -> "English".
// Маршруты под base: BASE_URL ("/cv/") - корень en, + "ru/" - русская версия.
const base = import.meta.env.BASE_URL;
const langHref = lang === "en" ? `${base}ru/` : base;
const langLabel = lang === "en" ? "Русский" : "English";
---

<nav class="dock" aria-label={t(lang, "dockNav")}>
    <a
        class="dock-button"
        href={langHref}
        data-tooltip={langLabel}
        aria-label={langLabel}
    >
        <span class="material-symbols-outlined" aria-hidden="true"
            >language</span
        >
    </a>
    <button
        class="dock-button"
        type="button"
        data-action="theme"
        data-tooltip={t(lang, "themeToggle")}
        aria-label={t(lang, "themeToggle")}
    >
        <span class="material-symbols-outlined" aria-hidden="true">routine</span
        >
    </button>
    <button
        class="dock-button"
        type="button"
        data-action="download"
        data-tooltip={t(lang, "downloadPdf")}
        aria-label={t(lang, "downloadPdf")}
    >
        <span class="material-symbols-outlined" aria-hidden="true"
            >download</span
        >
    </button>
    <button
        class="dock-button"
        type="button"
        data-action="print"
        data-tooltip={t(lang, "print")}
        aria-label={t(lang, "print")}
    >
        <span class="material-symbols-outlined" aria-hidden="true">print</span>
    </button>
    <a
        class="dock-button"
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-tooltip={t(lang, "sourceCode")}
        aria-label={t(lang, "sourceCode")}
    >
        <span class="material-symbols-outlined" aria-hidden="true">code</span>
    </a>
</nav>

<!-- Переключатель темы: toggles data-theme на <html>, пишет в localStorage.
     Инлайн-скрипт в BaseLayout уже применил тему до покраски; здесь только
     переключение по клику. -->
<script is:inline>
    (function () {
        var btn = document.querySelector('.dock-button[data-action="theme"]');
        if (!btn) return;
        btn.addEventListener("click", function () {
            var cur =
                document.documentElement.getAttribute("data-theme") || "light";
            var next = cur === "dark" ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", next);
            localStorage.setItem("theme", next);
        });
    })();
</script>

<!-- Печать и скачивание PDF: пока оба вызывают window.print() (диалог браузера,
     "Сохранить как PDF"). Временная реализация - стилизация печати (print.css,
     @page A4) на этапе E. -->
<script is:inline>
    (function () {
        var buttons = document.querySelectorAll(
            '.dock-button[data-action="print"], .dock-button[data-action="download"]',
        );
        buttons.forEach(function (b) {
            b.addEventListener("click", function () {
                window.print();
            });
        });
    })();
</script>
