---
import type { Cv } from "../../data/cv/schema";
import { formatPeriod, type Locale } from "../../lib/format";

interface Props {
    lang: Locale;
    job: Cv["experience"][number];
}

const { lang, job } = Astro.props;
---

<article class="dated-entry">
    <p class="entry-period">{formatPeriod(job.period, lang)}</p>
    <div class="entry-info">
        <!-- hgroup: a heading with its subtitle. The role is a paragraph, not
             a lower heading - it labels the same entry, not a subsection. -->
        <hgroup class="entry-head">
            <h3 class="entry-title">{job.company}</h3>
            <p class="entry-subtitle">{job.role}</p>
        </hgroup>
        <ul class="achievements">
            {job.achievements.map((a) => <li>{a}</li>)}
        </ul>
        <ul class="skill-list">
            {job.skills.map((s) => <li>{s}</li>)}
        </ul>
    </div>
</article>
