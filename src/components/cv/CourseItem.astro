---
import type { Cv } from "../../data/cv/schema";
import { formatPeriod, type Locale } from "../../lib/format";

interface Props {
    lang: Locale;
    course: Cv["courses"][number];
}

const { lang, course } = Astro.props;
---

<article class="dated-entry">
    <p class="entry-period">{formatPeriod(course.period, lang)}</p>
    <div class="entry-info">
        <h3 class="entry-title">{course.institution}</h3>
        <p class="entry-subtitle">{course.course}</p>
        <ul class="skill-list">
            {course.skills.map((s) => <li>{s}</li>)}
        </ul>
    </div>
</article>
