---
import type { Cv } from "../../data/cv/schema";
import { formatPeriod, type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    experience: Cv["experience"];
}

const { lang, experience } = Astro.props;

// Most recent job on top: sort by start (YYYY-MM) descending. String
// sorting of "YYYY-MM" matches chronological order.
const sorted = [...experience].sort((a, b) =>
    b.period.start.localeCompare(a.period.start),
);
---

<section aria-labelledby="experience-heading" id="experience">
    <div class="experience-container">
        {
            sorted.map((job, i) => {
                const block = (
                    <div class="job-block">
                        <p class="timestamp">
                            {formatPeriod(job.period, lang)}
                        </p>
                        <div class="job-info">
                            <h3>{job.company}</h3>
                            <h4>{job.role}</h4>
                            <ul class="achievements">
                                {job.achievements.map((a) => (
                                    <li>{a}</li>
                                ))}
                            </ul>
                            <ul class="skill-list">
                                {job.skills.map((s) => (
                                    <li>{s}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
                );
                // Heading + first entry in one box (.section-lead) so the
                // heading does not get orphaned from its content when printing.
                return i === 0 ? (
                    <div class="section-lead">
                        <h2 class="container-heading" id="experience-heading">
                            {t(lang, "experience")}
                        </h2>
                        {block}
                    </div>
                ) : (
                    block
                );
            })
        }
    </div>
</section>
