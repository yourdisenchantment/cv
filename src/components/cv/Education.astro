---
import type { Cv } from "../../data/cv/schema";
import { formatPeriod, type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    education: Cv["education"];
}

const { lang, education } = Astro.props;

// Новое сверху: сортировка по start (YYYY-MM) по убыванию. Строковая
// сортировка "YYYY-MM" совпадает с хронологической. Порядок в JSON не важен.
const sorted = [...education].sort((a, b) =>
    b.period.start.localeCompare(a.period.start),
);
---

<section aria-labelledby="education-heading" id="education">
    <div class="education-container">
        {
            sorted.map((e, i) => {
                const block = (
                    <div class="edu-block">
                        <p class="timestamp">{formatPeriod(e.period, lang)}</p>
                        <div class="edu-info">
                            <h3>{e.institution}</h3>
                            <h4>{e.faculty}</h4>
                            <p>{e.degree}</p>
                            {e.honors && <p class="honors">{e.honors}</p>}
                        </div>
                    </div>
                );
                // Заголовок + первая запись в одном боксе (.section-lead),
                // чтобы при печати заголовок не отрывался от содержимого.
                return i === 0 ? (
                    <div class="section-lead">
                        <h2 class="container-heading" id="education-heading">
                            {t(lang, "education")}
                        </h2>
                        {block}
                    </div>
                ) : (
                    block
                );
            })
        }
    </div>
</section>
