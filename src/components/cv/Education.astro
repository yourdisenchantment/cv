---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";
import EducationItem from "./EducationItem.astro";

interface Props {
    lang: Locale;
    education: Cv["education"];
}

const { lang, education } = Astro.props;

// Newest on top: sort by start (YYYY-MM) descending. String sorting of
// "YYYY-MM" matches chronological order. JSON order does not matter.
const sorted = [...education].sort((a, b) =>
    b.period.start.localeCompare(a.period.start),
);

// First entry is glued to the heading (.section-lead) so the heading is not
// orphaned at a page bottom in print; the rest flow after.
const [first, ...rest] = sorted;
---

<section aria-labelledby="education-heading" id="education">
    <div class="section-lead">
        <h2 class="section-heading" id="education-heading">
            {t(lang, "education")}
        </h2>
        {first && <EducationItem edu={first} lang={lang} />}
    </div>
    {
        rest.length > 0 && (
            <div class="section-body">
                {rest.map((edu) => (
                    <EducationItem edu={edu} lang={lang} />
                ))}
            </div>
        )
    }
</section>
