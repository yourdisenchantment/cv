---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    awards: Cv["awards"];
}

const { lang, awards } = Astro.props;
---

<section aria-labelledby="awards-heading" id="awards">
    <h2 class="container-heading" id="awards-heading">{t(lang, "awards")}</h2>
    <ul class="awards-list">
        {awards.map((a) => <li>{a}</li>)}
    </ul>
    <p class="scans-note">{t(lang, "scansOnRequest")}</p>
</section>
