---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    achievements: Cv["achievements"];
}

const { lang, achievements } = Astro.props;

// Achievements are strings or { text, file? } objects - normalize to objects.
// file - a path under public/ ("/documents/..."); under base it needs the
// BASE_URL prefix, like the favicon.
const base = import.meta.env.BASE_URL;
const items = achievements.map((a) =>
    typeof a === "string" ? { text: a, file: undefined } : a,
);
---

<section aria-labelledby="achievements-heading" id="achievements">
    <h2 class="section-heading" id="achievements-heading">
        {t(lang, "achievements")}
    </h2>
    <div class="section-body">
        <ul class="awards-list">
            {
                items.map((a) => (
                    <li>
                        {a.text}
                        {a.file && (
                            <a
                                class="pdf-badge"
                                href={base + a.file.replace(/^\//, "")}
                                target="_blank"
                                rel="noopener noreferrer"
                                data-tooltip={t(lang, "openInNewTab")}
                            >
                                {t(lang, "pdfLink")}
                                <span class="visually-hidden">
                                    ({t(lang, "openInNewTab")})
                                </span>
                            </a>
                        )}
                    </li>
                ))
            }
        </ul>
        <p class="scans-note">{t(lang, "scansOnRequest")}</p>
    </div>
</section>
