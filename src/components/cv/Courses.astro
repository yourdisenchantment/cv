---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";
import CourseItem from "./CourseItem.astro";

interface Props {
    lang: Locale;
    courses: Cv["courses"];
}

const { lang, courses } = Astro.props;

// Newest on top: sort by start (YYYY-MM) descending. String sorting of
// "YYYY-MM" matches chronological order. JSON order does not matter.
const sorted = [...courses].sort((a, b) =>
    b.period.start.localeCompare(a.period.start),
);

// First entry is glued to the heading (.section-lead) so the heading is not
// orphaned at a page bottom in print; the rest flow in .section-body.
const [first, ...rest] = sorted;
---

<section aria-labelledby="courses-heading" id="courses">
    <div class="section-lead">
        <h2 class="section-heading" id="courses-heading">
            {t(lang, "courses")}
        </h2>
        {first && <CourseItem course={first} lang={lang} />}
    </div>
    {
        rest.length > 0 && (
            <div class="section-body">
                {rest.map((course) => (
                    <CourseItem course={course} lang={lang} />
                ))}
            </div>
        )
    }
</section>
