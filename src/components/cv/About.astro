---
import type { Cv } from "../../data/cv/schema";
import { formatBirthDate, type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    about: Cv["about"];
}

const { lang, about } = Astro.props;

// The photo lives in public/ (about.photo - "/images/..."); under base it
// needs a prefix: BASE_URL ("/cv/") + the path without a leading slash.
const photoSrc = import.meta.env.BASE_URL + about.photo.replace(/^\//, "");
---

<section aria-labelledby="about-heading" id="about">
    <div class="about-container">
        <span
            class="about-photo"
            data-tooltip={about.name}
            data-tooltip-pos="bottom"
        >
            <img alt={`${about.name}, ${about.role}`} src={photoSrc} />
        </span>
        <div class="about-info">
            <h1 id="about-heading">{about.name}</h1>
            <p class="role">{about.role}</p>
            <p>
                <strong>{t(lang, "birthDate")}:</strong>
                {formatBirthDate(about.birthDate, lang)}
            </p>
            <p>
                <strong>{t(lang, "city")}:</strong>
                {about.city}
            </p>
            {
                about.availability && (
                    <p class="availability">{about.availability}</p>
                )
            }
        </div>
        <p class="summary">{about.summary}</p>
    </div>
</section>

<!-- Easter egg: every 10 clicks on the photo toggle easter <-> original
     (public/images/easter.png). No cursor:pointer - it stays hidden. Print/PDF
     (beforeprint) - always the original photo, afterprint restores whatever
     was shown before printing. -->
<script is:inline>
    (function () {
        var img = document.querySelector("#about .about-container img");
        if (!img) return;
        var original = img.src;
        // Derive the easter path from original (same folder, same base):
        // only the file name changes. So base need not be passed to the script.
        var egg = original.replace(/[^/]+$/, "easter.png");
        var clicks = 0;
        var onEgg = false; // easter is currently shown
        img.addEventListener("click", function () {
            clicks++;
            if (clicks < 10) return;
            clicks = 0; // reset: a toggle every 10 clicks
            onEgg = !onEgg;
            img.src = onEgg ? egg : original;
        });
        // Print and PDF - always the original photo.
        window.addEventListener("beforeprint", function () {
            img.src = original;
        });
        window.addEventListener("afterprint", function () {
            img.src = onEgg ? egg : original;
        });
    })();
</script>
