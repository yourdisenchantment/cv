---
import { Image } from "astro:assets";
import type { Cv } from "../../data/cv/schema";
import { formatBirthDate, type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";
import { photoMeta } from "../../lib/photo";

interface Props {
    lang: Locale;
    about: Cv["about"];
}

const { lang, about } = Astro.props;

// The photo is an src/assets asset optimized by astro:assets: webp, 1x/2x
// variants for the fixed CSS height (--photo-height), hashed URL under base.
const photo = photoMeta(about.photo);
---

<section aria-labelledby="about-heading" id="about">
    <h1 class="visually-hidden">{t(lang, "resumeTitle")}</h1>
    <!-- The section label is a hidden "About" heading: the visible name is a
         person, not a section title, so it stays a styled paragraph. -->
    <h2 class="visually-hidden" id="about-heading">{t(lang, "about")}</h2>
    <div class="section-body">
        <div
            class="about-photo"
            data-tooltip={about.name}
            data-tooltip-pos="bottom"
        >
            <Image
                alt={`${about.name}, ${about.role}`}
                src={photo}
                height={200}
                densities={[1, 2]}
                format="webp"
                loading="eager"
            />
        </div>
        <div class="about-info">
            <p class="about-name">{about.name}</p>
            <p class="role">{about.role}</p>
            <dl class="about-facts">
                <div>
                    <dt>{t(lang, "birthDate")}:</dt>
                    <dd>{formatBirthDate(about.birthDate, lang)}</dd>
                </div>
                <div>
                    <dt>{t(lang, "city")}:</dt>
                    <dd>{about.city}</dd>
                </div>
            </dl>
            {
                about.availability && (
                    <p class="availability">{about.availability}</p>
                )
            }
        </div>
        <p class="about-summary">{about.summary}</p>
        {
            about.research && (
                <dl class="about-facts about-research">
                    <div>
                        <dt>{t(lang, "researchFocus")}:</dt>
                        <dd>{about.research}</dd>
                    </div>
                </dl>
            )
        }
    </div>
</section>
