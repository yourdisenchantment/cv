---
import type { Cv } from "../../data/cv/schema";
import { formatBirthDate, type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    about: Cv["about"];
}

const { lang, about } = Astro.props;

// The photo lives in public/ (about.photo - "/images/..."); under base it
// needs a prefix: BASE_URL ("/cv/") + the path without a leading slash.
const photoSrc = import.meta.env.BASE_URL + about.photo.replace(/^\//, "");
---

<section aria-labelledby="about-heading" id="about">
    <div class="about-container">
        <span
            class="about-photo"
            data-tooltip={about.name}
            data-tooltip-pos="bottom"
        >
            <img alt={`${about.name}, ${about.role}`} src={photoSrc} />
        </span>
        <div class="about-info">
            <h1 class="visually-hidden">{t(lang, "resumeTitle")}</h1>
            <h2 class="section-heading" id="about-heading">{about.name}</h2>
            <p class="role">{about.role}</p>
            <p>
                <strong>{t(lang, "birthDate")}:</strong>
                {" "}
                {formatBirthDate(about.birthDate, lang)}
            </p>
            <p>
                <strong>{t(lang, "city")}:</strong>
                {" "}
                {about.city}
            </p>
            {
                about.availability && (
                    <p class="availability">{about.availability}</p>
                )
            }
        </div>
        <p class="summary">{about.summary}</p>
    </div>
</section>
