---
import type { Cv } from "../../data/cv/schema";
import { formatPeriod, type Locale } from "../../lib/format";

interface Props {
    lang: Locale;
    edu: Cv["education"][number];
}

const { lang, edu } = Astro.props;

// Middle dot (U+00B7) separator for the degree line. Built via fromCharCode
// to keep the source ASCII-only.
const sep = String.fromCharCode(0xb7);

// Degree and honors on one line, separated by the middle dot (sep, U+00B7).
// Built as one string so JSX does not slip in an extra space.
const degreeLine = edu.honors
    ? `${edu.degree} ${sep} ${edu.honors}`
    : edu.degree;
---

<article class="dated-entry">
    <p class="entry-period">{formatPeriod(edu.period, lang)}</p>
    <div class="entry-info">
        <h3 class="entry-title">{edu.institution}</h3>
        <p class="entry-subtitle">{edu.faculty}</p>
        {edu.department && <p class="entry-note">{edu.department}</p>}
        <p class="entry-text">{degreeLine}</p>
    </div>
</article>
