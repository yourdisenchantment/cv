---
import type { Cv } from "../../data/cv/schema";
import { formatPeriod, type Locale } from "../../lib/format";

interface Props {
    lang: Locale;
    edu: Cv["education"][number];
}

const { lang, edu } = Astro.props;
---

<article class="dated-entry">
    <p class="entry-period">{formatPeriod(edu.period, lang)}</p>
    <div class="entry-info">
        <h3 class="entry-title">{edu.institution}</h3>
        <p class="entry-subtitle">{edu.faculty}</p>
        {
            (edu.department || edu.code) && (
                <p class="entry-note dot-row">
                    {edu.department && <span>{edu.department}</span>}
                    {edu.code && (
                        <span class={edu.department ? "dot-sep" : ""}>
                            {edu.code}
                        </span>
                    )}
                </p>
            )
        }
        <!-- Degree and honors: the same dot-row + dot-sep pattern as the
             experience head (see cv-layout.css). -->
        <p class="entry-text dot-row">
            <span>{edu.degree}</span>
            {edu.honors && <span class="dot-sep">{edu.honors}</span>}
        </p>
    </div>
</article>
