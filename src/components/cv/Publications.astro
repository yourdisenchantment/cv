---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";
import PublicationItem from "./PublicationItem.astro";

interface Props {
    lang: Locale;
    publications: Cv["publications"];
}

const { lang, publications } = Astro.props;

// The first publication is glued to the heading (.section-lead) so the heading
// is never orphaned at a page bottom in print; the rest of the list flows after.
const [first, ...rest] = publications;
---

<section aria-labelledby="publications-heading" id="publications">
    <div class="section-lead">
        <h2 class="section-heading" id="publications-heading">
            {t(lang, "publications")}
        </h2>
        {first && <PublicationItem pub={first} lang={lang} />}
    </div>
    {
        rest.length > 0 && (
            <div class="section-body">
                {rest.map((pub) => (
                    <PublicationItem pub={pub} lang={lang} />
                ))}
            </div>
        )
    }
</section>
