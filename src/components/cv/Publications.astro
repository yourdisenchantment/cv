---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    publications: Cv["publications"];
}

const { lang, publications } = Astro.props;

// kind -> ключ i18n-метки. level -> ключ i18n-метки (только для ВКР).
const kindKey = {
    article: "kindArticle",
    thesis: "kindThesis",
    patent: "kindPatent",
    vkr: "kindVkr",
    dataset: "kindDataset",
} as const;
const levelKey = {
    bachelor: "levelBachelor",
    master: "levelMaster",
} as const;

// Метка публикации: для ВКР - "ВКР (Магистратура), 2 курс" / "Graduation
// thesis (Master), Year 2"; иначе - просто kind. Порядок слова "курс/Year"
// зависит от локали: ru "2 курс", en "Year 2".
function meta(pub: Cv["publications"][number]): string {
    const kind = t(lang, kindKey[pub.kind]);
    if (pub.kind === "vkr" && pub.level) {
        const level = t(lang, levelKey[pub.level]);
        const course = pub.course
            ? lang === "en"
                ? `, ${t(lang, "course")} ${pub.course}`
                : `, ${pub.course} ${t(lang, "course")}`
            : "";
        return `${kind} (${level})${course}`;
    }
    return kind;
}

// Текст ссылки: полный адрес без схемы (https://), чтобы в PDF ссылка читалась
// целиком, а одинаковые домены (напр. elibrary.ru) различались между собой.
function linkText(url: string): string {
    return url.replace(/^https?:\/\//, "");
}
---

<section aria-labelledby="publications-heading" id="publications">
    <div class="publications">
        {
            publications.map((pub, i) => {
                const block = (
                    <div class="publication-item">
                        <span class="publication-meta">{meta(pub)}</span>
                        <span class="publication-title">{pub.title}</span>
                        <ul class="publication-links">
                            {pub.urls.map((u) => (
                                <li>
                                    <a
                                        class="animated-link"
                                        href={u}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        data-tooltip={t(lang, "openInNewTab")}
                                    >
                                        {linkText(u)}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                );
                // Заголовок + первая запись в одном боксе (.section-lead),
                // чтобы при печати заголовок не отрывался от содержимого.
                return i === 0 ? (
                    <div class="section-lead">
                        <h2 class="container-heading" id="publications-heading">
                            {t(lang, "publications")}
                        </h2>
                        {block}
                    </div>
                ) : (
                    block
                );
            })
        }
    </div>
</section>
