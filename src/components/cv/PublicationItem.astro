---
import type { Cv } from "../../data/cv/schema";
import { type Locale } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    pub: Cv["publications"][number];
}

const { lang, pub } = Astro.props;

// kind -> i18n label key. level -> i18n label key (graduation thesis only).
const kindKey = {
    article: "kindArticle",
    thesis: "kindThesis",
    patent: "kindPatent",
    vkr: "kindVkr",
    dataset: "kindDataset",
    collection: "kindCollection",
    journal: "kindJournal",
} as const;
const levelKey = {
    bachelor: "levelBachelor",
    master: "levelMaster",
} as const;
const indexKey = {
    vak: "indexVak",
    rinc: "indexRinc",
} as const;

// Publication label: for a graduation thesis - "ВКР (Магистратура), 2 курс" /
// "Graduation thesis (Master), Year 2"; otherwise just the kind. The position
// of the "year" word depends on locale: ru "2 курс", en "Year 2".
function meta(pub: Cv["publications"][number]): string {
    const kind = t(lang, kindKey[pub.kind]);
    if (pub.kind === "vkr" && pub.level) {
        const level = t(lang, levelKey[pub.level]);
        const course = pub.course
            ? lang === "en"
                ? `, ${t(lang, "course")} ${pub.course}`
                : `, ${pub.course} ${t(lang, "course")}`
            : "";
        return `${kind} (${level})${course}`;
    }
    return kind;
}

// Link text: the full address without the scheme (https://), so in the PDF the
// link reads in full and identical domains (e.g. elibrary.ru) stay distinct.
function linkText(url: string): string {
    return url.replace(/^https?:\/\//, "");
}
---

<article class="publication-entry">
    <p class="entry-meta dot-row">
        <span>{meta(pub)}</span>
        {
            pub.index && (
                <span class="dot-sep">{t(lang, indexKey[pub.index])}</span>
            )
        }
    </p>
    <h3 class="entry-title">{pub.title}</h3>
    <ul class="entry-links">
        {
            pub.urls.map((u) => (
                <li>
                    <a
                        class="animated-link"
                        href={u}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-tooltip={t(lang, "openInNewTab")}
                    >
                        {linkText(u)}
                        {/* Screen-reader announcement of the new tab (the
                            tooltip is visual only). */}
                        <span class="visually-hidden">
                            ({t(lang, "openInNewTab")})
                        </span>
                    </a>
                </li>
            ))
        }
    </ul>
</article>
