---
import type { Cv } from "../../data/cv/schema";
import { type Locale, linkHostPath } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    contacts: Cv["contacts"];
}

const { lang, contacts } = Astro.props;

// Groups: contact (email/messenger/site) and resource (github/gitlab/...).
// Archived contacts go to the end of their group.
const groupOrder: Array<"contact" | "resource"> = ["contact", "resource"];
const grouped = groupOrder
    .map((g) => ({
        group: g,
        items: contacts
            .filter((c) => c.group === g)
            .sort(
                (a, b) =>
                    Number(a.archived ?? false) - Number(b.archived ?? false),
            ),
    }))
    .filter((g) => g.items.length > 0);
---

<section aria-labelledby="contacts-heading" id="contacts">
    <h2 class="container-heading" id="contacts-heading">
        {t(lang, "contacts")}
    </h2>
    <div class="contact-container">
        {
            grouped.map(({ items }) => (
                <ul class="contact-group">
                    {items.map((c) => (
                        <li>
                            <strong>{c.label}:</strong>
                            {c.href ? (
                                <a
                                    class="animated-link"
                                    href={c.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    data-tooltip={t(lang, "openInNewTab")}
                                >
                                    {linkHostPath(c.href)}
                                </a>
                            ) : (
                                <button
                                    class="copy-text"
                                    type="button"
                                    data-copy={c.value}
                                    data-tooltip={t(lang, "copy")}
                                    aria-label={`${t(lang, "copyEmail")}: ${c.value}`}
                                >
                                    {c.value}
                                </button>
                            )}
                            {c.archived && (
                                <span class="archived">
                                    ({t(lang, "archived")})
                                </span>
                            )}
                        </li>
                    ))}
                </ul>
            ))
        }
    </div>
    <span
        class="visually-hidden"
        aria-live="polite"
        data-copy-status
        data-copied-text={t(lang, "copied")}></span>
</section>

<!-- Email copy: .copy-text buttons (contacts without href are always email).
     Click -> navigator.clipboard, a visual .copied mark, swap the tooltip to
     "Copied" and announce it in an aria-live region for screen readers. After
     1.2s everything returns to the initial state. No clipboard API - silent. -->
<script is:inline>
    (function () {
        var buttons = document.querySelectorAll(".copy-text");
        var status = document.querySelector("[data-copy-status]");
        if (!buttons.length || !navigator.clipboard) return;
        var copiedText = status ? status.getAttribute("data-copied-text") : "";
        buttons.forEach(function (b) {
            var copyTip = b.getAttribute("data-tooltip");
            b.addEventListener("click", function () {
                var value = b.getAttribute("data-copy");
                navigator.clipboard.writeText(value).then(function () {
                    b.classList.add("copied");
                    if (copiedText) b.setAttribute("data-tooltip", copiedText);
                    if (status && copiedText) {
                        status.textContent = "";
                        status.textContent = copiedText;
                    }
                    setTimeout(function () {
                        b.classList.remove("copied");
                        if (copyTip) b.setAttribute("data-tooltip", copyTip);
                    }, 1200);
                });
            });
        });
    })();
</script>
