---
import type { Cv } from "../../data/cv/schema";
import { type Locale, linkHostPath } from "../../lib/format";
import { t } from "../../lib/i18n";

interface Props {
    lang: Locale;
    contacts: Cv["contacts"];
}

const { lang, contacts } = Astro.props;

// Private phone, read from a gitignored src/data/private.json (template:
// private.example.json). import.meta.glob returns {} when the file is absent,
// so the public/CI build - which does not have it - simply omits the number;
// a local build picks it up. Rendered print-only (see .contact-print-only),
// so it lands only in a locally generated PDF, never in the deployed HTML.
const privateData = import.meta.glob("../../data/private.json", {
    eager: true,
    import: "default",
});
const phone = (Object.values(privateData)[0] as { phone?: string } | undefined)
    ?.phone;

// Groups: contact (email/messenger/site) and resource (github/gitlab/...).
// Archived contacts go to the end of their group.
const groupOrder: Array<"contact" | "resource"> = ["contact", "resource"];
const grouped = groupOrder
    .map((g) => ({
        group: g,
        items: contacts
            .filter((c) => c.group === g)
            .sort(
                (a, b) =>
                    Number(a.archived ?? false) - Number(b.archived ?? false),
            ),
    }))
    .filter((g) => g.items.length > 0);
---

<section aria-labelledby="contacts-heading" id="contacts">
    <h2 class="section-heading" id="contacts-heading">
        {t(lang, "contacts")}
    </h2>
    <!-- <address>: the element for the page author's contact information.
         Each group is a <dl> of label: value pairs. -->
    <address class="section-body">
        {
            grouped.map(({ group, items }) => (
                <dl class="contact-group">
                    {items.map((c) => (
                        <div>
                            <dt>{c.label}:</dt>
                            <dd>
                                {c.href ? (
                                    <a
                                        class="animated-link"
                                        href={c.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        data-tooltip={t(lang, "openInNewTab")}
                                    >
                                        {linkHostPath(c.href)}
                                        {/* The tooltip is visual only - this
                                            line announces the new tab to
                                            screen readers. */}
                                        <span class="visually-hidden">
                                            ({t(lang, "openInNewTab")})
                                        </span>
                                    </a>
                                ) : (
                                    <a
                                        class="animated-link"
                                        href={`mailto:${c.value}`}
                                        data-tooltip={t(lang, "sendEmail")}
                                    >
                                        {c.value}
                                    </a>
                                )}
                                {c.archived && (
                                    <span class="archived">
                                        ({t(lang, "archived")})
                                    </span>
                                )}
                            </dd>
                        </div>
                    ))}
                    {group === "contact" && phone && (
                        <div class="contact-print-only">
                            <dt>{t(lang, "phone")}:</dt>
                            <dd>{phone}</dd>
                        </div>
                    )}
                </dl>
            ))
        }
    </address>
</section>
