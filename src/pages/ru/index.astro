---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Resume from "../../components/cv/Resume.astro";
import { getEntry } from "astro:content";

// Русская версия - маршрут '/ru/' (модель B: en по умолчанию на '/', ru вручную).
const lang = "ru";
const cv = await getEntry("cv", lang);
if (!cv) throw new Error(`CV entry '${lang}' not found in collection 'cv'`);
---

<BaseLayout
    lang={lang}
    title={cv.data.meta.title}
    description={cv.data.meta.description}
>
    <Resume lang={lang} data={cv.data} />
</BaseLayout>
