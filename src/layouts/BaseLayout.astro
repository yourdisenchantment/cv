---
import "../styles/reset.css";
import "../styles/fonts.css";
import "../styles/variables.css";
import "../styles/styles.css";
import "../styles/cv-layout.css";
import "../styles/print.css";
import "../styles/debug.css";
import Dock from "../components/Dock.astro";

interface Props {
    lang: "ru" | "en";
    title: string;
    description?: string;
    jsonLd?: Record<string, unknown>;
}

const { lang, title, description, jsonLd } = Astro.props;

// debug-boxes - только в dev: красная граница при наведении (см. debug.css).
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description ?? ""} />
        {
            jsonLd && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={JSON.stringify(jsonLd)}
                />
            )
        }
        <!-- Применяет тему до первой покраски, чтобы не было вспышки светлой
             темы (FOUC). Без JS fallback - :root (light). Кнопка-переключатель
             и запись в localStorage появятся с меню иконок (этап 5/6). -->
        <script is:inline>
            (function () {
                var saved = localStorage.getItem("theme");
                var prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                var theme = saved || (prefersDark ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
            })();
        </script>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{title}</title>
    </head>
    <body class:list={[isDev && "debug-boxes"]}>
        <slot />
        <Dock lang={lang} />
        <!-- Тултипы (data-tooltip) dismissible по Escape: ставим класс на <html>,
             снимаем при движении мыши / смене фокуса. CSS-правило - styles.css. -->
        <script is:inline>
            (function () {
                var root = document.documentElement;
                document.addEventListener("keydown", function (e) {
                    if (e.key === "Escape")
                        root.classList.add("tooltips-dismissed");
                });
                ["pointermove", "focusin"].forEach(function (ev) {
                    document.addEventListener(ev, function () {
                        root.classList.remove("tooltips-dismissed");
                    });
                });
            })();
        </script>
    </body>
</html>
