---
import "../styles/reset.css";
import "../styles/fonts.css";
import "../styles/variables.css";
import "../styles/styles.css";
import "../styles/cv-layout.css";
import "../styles/print.css";
import "../styles/debug.css";
import Dock from "../components/Dock.astro";

interface Props {
    lang: "ru" | "en";
    title: string;
    description?: string;
    jsonLd?: Record<string, unknown>;
    // Easter-egg pages: excluded from search indexing.
    noindex?: boolean;
}

const { lang, title, description, jsonLd, noindex = false } = Astro.props;

// debug-boxes - dev only: red outline on hover (see debug.css).
const isDev = import.meta.env.DEV;

// base ("/cv/" in prod, "/" otherwise) - prefix for static assets in public/.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description ?? ""} />
        {noindex && <meta name="robots" content="noindex" />}
        {
            jsonLd && (
                <script
                    is:inline
                    type="application/ld+json"
                    set:html={JSON.stringify(jsonLd)}
                />
            )
        }
        <!-- Applies the theme before first paint to avoid a flash of the light
             theme (FOUC). Without JS the fallback is :root (light). The toggle
             button and the localStorage write live in the Dock. -->
        <script is:inline>
            (function () {
                var saved = localStorage.getItem("theme");
                var prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                var theme = saved || (prefersDark ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
            })();
        </script>
        <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
        <link rel="icon" href={`${base}favicon.ico`} />
        <title>{title}</title>
    </head>
    <body class:list={[isDev && "debug-boxes"]}>
        <slot />
        <Dock lang={lang} />
        <!-- Tooltips (data-tooltip) are dismissible via Escape: set a class on
             <html>, drop it on pointer move / focus change. CSS in styles.css. -->
        <script is:inline>
            (function () {
                var root = document.documentElement;
                document.addEventListener("keydown", function (e) {
                    if (e.key === "Escape")
                        root.classList.add("tooltips-dismissed");
                });
                ["pointermove", "focusin"].forEach(function (ev) {
                    document.addEventListener(ev, function () {
                        root.classList.remove("tooltips-dismissed");
                    });
                });
            })();
        </script>
    </body>
</html>
